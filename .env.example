# DDR Intelligence Engine — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Required: Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Change the model (llama-3.1-8b-instant has 500K tokens/day free)
GROQ_MODEL=llama-3.1-8b-instant

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Output directory for generated PDFs
OUTPUT_DIR=outputs
